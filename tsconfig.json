{
    "compilerOptions": {
        "target": "ES2022",
        "lib": [
            "DOM",
            "ES2022"
        ],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "noEmit": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "types": [
            "chrome",
            "node",
            "vite/client"
        ]
    },
    "include": [
        "src/**/*.ts",
        "scripts/**/*.ts",
        "spec/**/*.ts",
        "vite.config.ts"
    ]
}
