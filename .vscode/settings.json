{
    "1password.editor.suggestStorage": false,
    "1password.items.cacheValues": false,
    "[css]": {
        "editor.defaultFormatter": "dprint.dprint"
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "dprint.dprint"
    },
    "[html]": {
        "editor.defaultFormatter": "dprint.dprint"
    },
    "[javascript]": {
        "editor.defaultFormatter": "dprint.dprint"
    },
    "[javascriptreact]": {
        "editor.defaultFormatter": "dprint.dprint"
    },
    "[json]": {
        "editor.defaultFormatter": "dprint.dprint"
    },
    "[jsonc]": {
        "editor.defaultFormatter": "dprint.dprint"
    },
    "[less]": {
        "editor.defaultFormatter": "dprint.dprint"
    },
    "[markdown]": {
        "editor.defaultFormatter": "dprint.dprint",
        "editor.formatOnSave": true,
        "editor.rulers": [
            80
        ],
        "editor.wordWrapColumn": 79,
        "rewrap.wrappingColumn": 75
    },
    "[plaintext]": {
        "editor.rulers": [
            80
        ],
        "editor.wordWrapColumn": 79,
        "rewrap.wrappingColumn": 79
    },
    "[scss]": {
        "editor.defaultFormatter": "dprint.dprint"
    },
    "[typescript]": {
        "editor.defaultFormatter": "dprint.dprint"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "dprint.dprint"
    },
    "[yaml]": {
        "editor.defaultFormatter": "dprint.dprint",
        "editor.tabSize": 2
    },
    "accessibility.signalOptions.volume": 0,
    "chat.agent.maxRequests": 100,
    "chat.mcp.gallery.enabled": true,
    "chat.viewSessions.enabled": false,
    "claudeCode.preferredLocation": "sidebar",
    "debug.autoExpandLazyVariables": "on",
    "diffEditor.ignoreTrimWhitespace": false,
    "diffEditor.renderSideBySide": true,
    "editor.accessibilitySupport": "off",
    "editor.detectIndentation": false,
    "editor.fontFamily": "Input",
    "editor.formatOnSave": true,
    "editor.insertSpaces": true,
    "editor.minimap.enabled": false,
    "editor.multiCursorModifier": "ctrlCmd",
    "editor.rulers": [
        130
    ],
    "editor.suggestSelection": "first",
    "editor.tabSize": 4,
    "editor.unicodeHighlight.ambiguousCharacters": false,
    "editor.wordWrapColumn": 130,
    "files.exclude": {
        "**/.classpath": true,
        "**/.factorypath": true,
        "**/.project": true,
        "**/.settings": true
    },
    "git.openRepositoryInParentFolders": "always",
    "github.copilot.chat.agent.autoFix": false,
    "github.copilot.chat.agent.currentEditorContext.enabled": true,
    "github.copilot.chat.codesearch.enabled": true,
    "github.copilot.enable": {
        "*": true,
        "markdown": false,
        "plaintext": false,
        "scminput": false
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "githubLocalActions.actCommand": "act --env-file .env",
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-5",
    "gitlens.currentLine.enabled": false,
    "gitlens.currentLine.pullRequests.enabled": false,
    "gitlens.launchpad.indicator.enabled": false,
    "javascript.format.semicolons": "remove",
    "js/ts.format.semicolons": "remove",
    "json.maxItemsComputed": 100000,
    "json.schemaDownload.trustedDomains": {
        "https://developer.microsoft.com/json-schemas/": true,
        "https://dprint.dev/": true,
        "https://json-schema.org/": true,
        "https://json.schemastore.org/": true,
        "https://raw.githubusercontent.com/DavidAnson/markdownlint/v0.40.0/schema/markdownlint-config-schema.json": true,
        "https://raw.githubusercontent.com/devcontainers/spec/": true,
        "https://raw.githubusercontent.com/microsoft/vscode/": true,
        "https://schemastore.azurewebsites.net/": true,
        "https://www.schemastore.org/": true
    },
    "markdownlint.ignore": [
        "**/.serena/**"
    ],
    "redhat.telemetry.enabled": false,
    "terminal.integrated.scrollback": 100000,
    "typescript.format.semicolons": "remove",
    "window.commandCenter": false,
    "workbench.editor.enablePreview": false,
    "workbench.secondarySideBar.defaultVisibility": "visible",
    "workbench.startupEditor": "none"
}
